{
  "type": "module",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.925.0",
    "@aws-sdk/lib-dynamodb": "^3.925.0",
    "@fastly/compute-js-opentelemetry": "^0.4.3",
    "@fastly/expressly": "^2.3.0",
    "@fastly/js-compute": "^3.33.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.63.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.37.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@fastly/cli": "^12.1.0",
    "@fastly/compute-testing": "^0.2.0",
    "@mswjs/http-middleware": "^0.10.3",
    "@types/express": "^5.0.5",
    "@vitest/ui": "^4.0.7",
    "aws-sdk-client-mock": "^4.1.0",
    "express": "^5.1.0",
    "msw": "^2.12.0",
    "typescript": "^5.2.2",
    "vitest": "^4.0.7"
  },
  "scripts": {
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "lint": "biome check .",
